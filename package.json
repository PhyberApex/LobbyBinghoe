    "@quasar/vite-plugin": "1.12.0",
    "@rushstack/eslint-patch": "1.16.1",
    "@tsconfig/node24": "24.0.4",
    "@types/jsdom": "28.0.3",
    "@types/node": "24.13.2",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.9.0",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.5.0",
